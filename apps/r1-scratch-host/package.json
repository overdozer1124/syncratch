    "@blocksync/project-snapshots-fs": "workspace:*",
    "@blocksync/project-store-sqlite": "workspace:*",
    "@blocksync/r1-persist-server": "workspace:*",
    "@playwright/test": "^1.52.0",
    "@types/better-sqlite3": "^7.6.13",
