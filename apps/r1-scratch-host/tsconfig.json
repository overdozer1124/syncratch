{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "rootDir": ".",
    "types": ["node"]
  },
  "include": ["spike/**/*.ts", "src/**/*.ts", "vitest.config.ts"],
  "exclude": ["spike/**/*.spec.ts"]
}
